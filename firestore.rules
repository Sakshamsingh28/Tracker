rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All project data is publicly readable (no auth)
    // In production, restrict write/delete access to authenticated admin users
    match /projects/{projectId} {
      allow read, write: if true;

      match /{subcollection}/{docId} {
        allow read, write: if true;
      }
    }
  }
}
